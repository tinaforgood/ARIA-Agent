<p>健全、完善</p></td>\n  </tr>\n  <tr>\n    <td colspan=\"2\"><p>医院医疗设备运维制度健全性</p></td>\n    <td colspan=\"2\"><p>健全、完善</p></td>\n  </tr>\n  <tr>\n    <td colspan=\"2\"><p>医院医疗设备质量控制机制健全性</p></td>\n    <td colspan=\"2\"><p>健全、完善</p></td>\n  </tr>\n  <tr>\n    <td rowspan=\"3\" colspan=\"2\"><p>满意度指标</p></td>\n    <td rowspan=\"3\" colspan=\"2\"><p>服务对象\n满意度指标</p></td>\n    <td colspan=\"2\"><p>设备使用人员满意度</p></td>\n    <td colspan=\"2\"><p>≥92%</p></td>\n  </tr>\n  <tr>\n    <td colspan=\"2\"><p>管理部门满意度</p></td>\n    <td colspan=\"2\"><p>≥92%</p></td>\n  </tr>\n  <tr>\n    <td colspan=\"2\"><p>患者满意度</p></td>\n    <td colspan=\"2\"><p>≥92%</p></td>\n  </tr>\n</table>",
